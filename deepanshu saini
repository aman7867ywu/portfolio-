<script>
  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if(e.isIntersecting){
        e.target.classList.add('revealed');
        // Animate skill bars
        e.target.querySelectorAll('.skill-fill').forEach(bar => {
          bar.style.width = bar.dataset.pct + '%';
        });
      }
    });
  }, {threshold: 0.15});
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Animate skill bars on page load if already visible
  document.querySelectorAll('.skill-fill').forEach(bar => {
    if(bar.closest('.revealed')) bar.style.width = bar.dataset.pct + '%';
  });

  // Typing effect for role
  const roles = ['Full Stack Developer', 'AI/ML Enthusiast', 'Open Source Contributor', 'Competitive Programmer'];
  let ri = 0, ci = 0, del = false;
  const roleEl = document.querySelector('.hero-role');
  const base = '';
  function type(){
    const cur = roles[ri];
    if(!del){
      roleEl.textContent = base + cur.slice(0, ++ci);
      if(ci === cur.length){ del = true; setTimeout(type, 1800); return; }
    } else {
      roleEl.textContent = base + cur.slice(0, --ci);
      if(ci === 0){ del = false; ri = (ri+1)%roles.length; }
    }
    setTimeout(type, del ? 50 : 80);
  }
  setTimeout(type, 1000);
</script>
